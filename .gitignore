__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# Model weights (trained on Colab, kept on Drive — never commit)
models/
checkpoints/
*.pt
*.bin
*.safetensors

# Secrets
.env
.env.local
*.key
*.pem

# Local backups
*.bak.py
candidate_config_*.bak.py
