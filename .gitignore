# M.I.N.E.R.V.A. — Git ignore patterns
# =====================================

# ---- Python cache + bytecode ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- pytest + coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.cover
*.py,cover

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Pipeline runtime artifacts (never commit) ----
# These are produced by the pipeline run; they belong in Drive/zip exports,
# not in version control.
data/raw/
data/processed/
data/features/
data/gpt2_neurosymbolic/
logs/
models/*.bin
models/*.pt
models/*.safetensors
models/*.json
!models/.gitkeep
generated/
reports/
!reports/.gitkeep

# ---- Local config / secrets ----
.env
.env.local
*.local

# ---- IDE + editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Build outputs ----
build/
dist/
*.egg-info/
*.egg

# ---- Allow these specific files even though parent dirs are ignored ----
!data/.gitkeep
!logs/.gitkeep
!models/.gitkeep
